{
  "info": {
    "name": "CloudMart - All Services",
    "_postman_id": "cloudmart-collection-2026",
    "description": "Complete API test collection for all CloudMart microservices. Set the {{base_url}} variable to http://localhost:3000 for local development via API Gateway.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "auth_token", "value": "" },
    { "key": "product_id", "value": "" },
    { "key": "cart_id", "value": "" },
    { "key": "order_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"gajananda@cloudmart.dev\",\n  \"password\": \"Secret@1234\",\n  \"firstName\": \"Gajananda\",\n  \"lastName\": \"Dev\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('auth_token', json.token);",
                  "pm.test('Token returned', () => pm.expect(json.token).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"gajananda@cloudmart.dev\",\n  \"password\": \"Secret@1234\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('auth_token', json.token);",
                  "pm.test('Token returned', () => pm.expect(json.token).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has email', () => pm.expect(json.email).to.be.a('string'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Product Service",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products?page=1&limit=10",
              "query": [
                { "key": "category", "value": "", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has items array', () => pm.expect(json.items).to.be.an('array'));",
                  "if (json.items.length > 0) { pm.collectionVariables.set('product_id', json.items[0].id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products/{{product_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has id', () => pm.expect(json.id).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mechanical Keyboard\",\n  \"description\": \"Cherry MX Red, tenkeyless, RGB backlit\",\n  \"price\": 129.99,\n  \"categoryId\": \"cat-electronics\",\n  \"stock\": 50\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('product_id', json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/products/{{product_id}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 119.99,\n  \"stock\": 45\n}"
            }
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/products/{{product_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Cart Service",
      "item": [
        {
          "name": "Get My Cart",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/cart",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('cart_id', json.cartId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/cart/items",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{product_id}}\",\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/cart/items/{{product_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }]
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/cart",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Order Service",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/orders",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "X-Correlation-ID", "value": "test-trace-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartId\": \"{{cart_id}}\",\n  \"shippingAddressId\": \"addr-kathmandu-001\",\n  \"paymentMethodId\": \"pm_test_card_visa\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('order_id', json.orderId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/orders/{{order_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }]
          }
        },
        {
          "name": "List My Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Payment Service",
      "item": [
        {
          "name": "Stripe Webhook (Simulate)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/payments/webhook",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Stripe-Signature", "value": "t=1609459200,v1=test_signature" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"payment_intent.succeeded\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"pi_test_123\",\n      \"metadata\": { \"orderId\": \"{{order_id}}\" },\n      \"amount\": 5998\n    }\n  }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Inventory Service",
      "item": [
        {
          "name": "Get Stock for Product",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/inventory/{{product_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }]
          }
        },
        {
          "name": "Reserve Stock",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/inventory/reserve",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{order_id}}\",\n  \"items\": [\n    { \"productId\": \"{{product_id}}\", \"quantity\": 2 }\n  ]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Health Checks",
      "item": [
        { "name": "API Gateway Health", "request": { "method": "GET", "url": "{{base_url}}/health" } },
        { "name": "Auth Service Health", "request": { "method": "GET", "url": "http://localhost:3002/health" } },
        { "name": "Product Service Health", "request": { "method": "GET", "url": "http://localhost:3003/health" } },
        { "name": "Cart Service Health", "request": { "method": "GET", "url": "http://localhost:3004/health" } },
        { "name": "Order Service Health", "request": { "method": "GET", "url": "http://localhost:3005/health" } },
        { "name": "Payment Service Health", "request": { "method": "GET", "url": "http://localhost:3006/health" } },
        { "name": "Inventory Service Health", "request": { "method": "GET", "url": "http://localhost:3007/health" } },
        { "name": "Notification Service Health", "request": { "method": "GET", "url": "http://localhost:3008/health" } },
        { "name": "Analytics Service Health", "request": { "method": "GET", "url": "http://localhost:3009/health" } }
      ]
    }
  ]
}
